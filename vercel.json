{
  "version": 2,
  "routes": [
    {
      "src": "^/$",
      "dest": "/today-operation.html"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/$1"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/api/index.js"
    }
  ]
}
